<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/customerportal/db" VERSION="20260418"
       COMMENT="XMLDB file for local_customerportal">
  <TABLES>
    <TABLE NAME="local_customerportal_request" COMMENT="Customer requests initiated from the portal">
      <FIELDS>
        <FIELD NAME="id"               TYPE="int"  LENGTH="10" NOTNULL="true"  SEQUENCE="true"/>
        <FIELD NAME="installation_id"  TYPE="char" LENGTH="36" NOTNULL="true"/>
        <FIELD NAME="catalog_entry_id" TYPE="char" LENGTH="36" NOTNULL="false"/>
        <FIELD NAME="request_type"     TYPE="char" LENGTH="64" NOTNULL="true"/>
        <FIELD NAME="message"          TYPE="text" NOTNULL="false"/>
        <FIELD NAME="userid"           TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="status"           TYPE="char" LENGTH="32" NOTNULL="true"  DEFAULT="pending"/>
        <FIELD NAME="directus_id"      TYPE="char" LENGTH="36" NOTNULL="false"/>
        <FIELD NAME="timecreated"      TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
        <FIELD NAME="timemodified"     TYPE="int"  LENGTH="10" NOTNULL="true"  DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="fk_user" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="installation_status" UNIQUE="false" FIELDS="installation_id, status"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
