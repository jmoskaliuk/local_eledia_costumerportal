{{!
    Requests page — list and new request form.
    @template local_customerportal/request_list
    @copyright 2026 eLeDia GmbH
    @license   https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="path-local-customerportal lh-plugin-shell lh-plugin-shell--wide">
    {{> local_customerportal/shell_header }}

    <div class="lh-plugin-content-area">
        {{#error}}
        <div class="alert alert-warning">{{error}}</div>
        {{/error}}

        {{#show_form}}
        <article class="lh-plugin-card">
            <div class="lh-plugin-card__top">
                <div class="lh-plugin-card__icon lh-plugin-card__icon--community" aria-hidden="true">
                    <i class="fa fa-plus"></i>
                </div>
                <div class="lh-plugin-card__meta">
                    <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} nav_requests, local_customerportal {{/str}}</div>
                    <h2 class="lh-plugin-card__title">{{#str}} request_create_heading, local_customerportal {{/str}}</h2>
                </div>
            </div>
            {{{form_html}}}
        </article>
        {{/show_form}}

        {{^show_form}}
        {{#can_create}}
        <div class="mb-3">
            <a href="{{url_new}}" class="lh-plugin-btn lh-plugin-btn--open">
                <i class="fa fa-plus" aria-hidden="true"></i>
                {{#str}} request_new, local_customerportal {{/str}}
            </a>
        </div>
        {{/can_create}}

        {{#has_requests}}
        <article class="lh-plugin-card">
            <div class="lh-plugin-card__top">
                <div class="lh-plugin-card__icon lh-plugin-card__icon--community" aria-hidden="true">
                    <i class="fa fa-inbox"></i>
                </div>
                <div class="lh-plugin-card__meta">
                    <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} nav_requests, local_customerportal {{/str}}</div>
                    <h2 class="lh-plugin-card__title">{{#str}} request_heading, local_customerportal {{/str}}</h2>
                </div>
            </div>
            <table class="table table-sm table-hover generaltable">
                <thead>
                    <tr>
                        <th>{{#str}} request_type, local_customerportal {{/str}}</th>
                        <th>{{#str}} request_status_header, local_customerportal {{/str}}</th>
                        <th>{{#str}} request_message, local_customerportal {{/str}}</th>
                        <th>{{#str}} request_date, local_customerportal {{/str}}</th>
                    </tr>
                </thead>
                <tbody>
                    {{#requests}}
                    <tr>
                        <td>{{request_type_label}}</td>
                        <td>
                            <span class="badge {{#status_local}}bg-success{{/status_local}}{{#status_error}}bg-danger{{/status_error}}">
                                {{status_label}}
                            </span>
                        </td>
                        <td>{{message}}</td>
                        <td>{{timecreated_str}}</td>
                    </tr>
                    {{/requests}}
                </tbody>
            </table>
        </article>
        {{/has_requests}}
        {{^has_requests}}
        {{^error}}
        <p class="text-muted">{{#str}} request_no_requests, local_customerportal {{/str}}</p>
        {{/error}}
        {{/has_requests}}
        {{/show_form}}
    </div>
</div>
