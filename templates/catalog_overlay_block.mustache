{{!
    Installation context overlay block — embedded in catalog_detail.mustache.
    @template local_customerportal/catalog_overlay_block
    @copyright 2026 eLeDia GmbH
    @license   https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="path-local-customerportal-overlay card mt-4">
    <div class="card-body">
        {{#is_installed}}
        <span class="badge bg-success me-2">{{#str}} overlay_installed, local_customerportal {{/str}}</span>
        {{#installed_version_summary}}<code class="small">{{installed_version_summary}}</code>{{/installed_version_summary}}
        {{/is_installed}}

        {{#recommended}}
        <span class="badge bg-primary me-2">{{#str}} overlay_recommended, local_customerportal {{/str}}</span>
        {{/recommended}}

        {{#compatibility_status}}
        {{#compatibility_compatible}}
        <span class="badge bg-success me-2">{{#str}} overlay_compatible, local_customerportal {{/str}}</span>
        {{/compatibility_compatible}}
        {{#compatibility_incompatible}}
        <span class="badge bg-danger me-2">{{#str}} overlay_incompatible, local_customerportal {{/str}}</span>
        {{/compatibility_incompatible}}
        {{#compatibility_unknown}}
        <span class="badge bg-secondary me-2">{{#str}} overlay_unknown_compatibility, local_customerportal {{/str}}</span>
        {{/compatibility_unknown}}
        {{/compatibility_status}}

        {{#requires_upgrade_first}}
        <div class="alert alert-warning mt-2 mb-0">
            {{#str}} overlay_requires_upgrade, local_customerportal {{/str}}
        </div>
        {{/requires_upgrade_first}}

        {{#note}}
        <p class="mt-2 mb-0 text-muted small">{{note}}</p>
        {{/note}}

        {{#can_create_request}}
        <div class="mt-3">
            <a href="{{url_request}}" class="btn btn-primary">
                {{#str}} request_new, local_customerportal {{/str}}
            </a>
        </div>
        {{/can_create_request}}
    </div>
</div>
