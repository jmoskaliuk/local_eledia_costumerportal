{{!
    Plugin detail page (public catalog + installation overlay).
    @template local_customerportal/catalog_detail
    @copyright 2026 eLeDia GmbH
    @license   https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="path-local-customerportal">
    {{> local_customerportal/nav_tabs }}

    {{#error}}
    <div class="alert alert-warning">{{error}}</div>
    {{/error}}

    {{^has_entry}}
    {{^error}}
    <p class="text-muted">{{#str}} plugin_not_found, local_customerportal {{/str}}</p>
    {{/error}}
    {{/has_entry}}

    {{#has_entry}}
    {{#classification.is_deprecated}}
    <div class="alert alert-danger" role="alert">
        <h5 class="alert-heading">
            {{#str}} plugin_deprecated_heading, local_customerportal {{/str}}
        </h5>
        <p class="mb-0">{{#str}} plugin_deprecated_text, local_customerportal {{/str}}</p>
        {{#classification.has_replacement}}
        <p class="mt-2 mb-0">
            {{#str}} plugin_deprecated_replacement, local_customerportal {{/str}}:
            <code>{{classification.replacement_entry_id}}</code>
        </p>
        {{/classification.has_replacement}}
    </div>
    {{/classification.is_deprecated}}

    <div class="row">
        <div class="col-md-8">
            <h2>{{entry.title}}</h2>
            <div class="mb-3 d-flex flex-wrap gap-1">
                {{#classification.has_pricing_model}}
                <span class="badge bg-light text-dark border">{{classification.pricing_model_label}}</span>
                {{/classification.has_pricing_model}}
                {{#classification.is_open_source}}
                <span class="badge bg-light text-dark border">
                    {{#str}} badge_open_source, local_customerportal {{/str}}
                </span>
                {{/classification.is_open_source}}
                {{#classification.is_eledia_product}}
                <span class="badge bg-primary">
                    {{#str}} badge_eledia_product, local_customerportal {{/str}}
                </span>
                {{/classification.is_eledia_product}}
                {{#classification.has_gdpr}}
                <span class="badge {{classification.gdpr_class}}">{{classification.gdpr_label}}</span>
                {{/classification.has_gdpr}}
                {{#classification.has_maintenance}}
                <span class="badge bg-light text-dark border">{{classification.maintenance_label}}</span>
                {{/classification.has_maintenance}}
            </div>
            <p class="lead">{{entry.description_public}}</p>

            {{#entry.proven_summary}}
            <div class="card mb-3">
                <div class="card-body">
                    <span class="badge bg-success me-2">{{badge}}</span>
                    {{summary}}
                    <span class="text-muted small ms-2">{{#str}} plugin_proven_reviewed_at, local_customerportal {{/str}}: {{reviewed_at}}</span>
                </div>
            </div>
            {{/entry.proven_summary}}

            {{#entry.docs_url}}
            <p>
                <a href="{{entry.docs_url}}" target="_blank" rel="noopener noreferrer" class="btn btn-outline-secondary">
                    {{#str}} plugin_docs, local_customerportal {{/str}}
                </a>
            </p>
            {{/entry.docs_url}}

            {{#entry.screenshots}}
            <h5>{{#str}} plugin_screenshots, local_customerportal {{/str}}</h5>
            <div class="d-flex flex-wrap gap-2 mb-4">
                {{#entry.screenshots}}
                <img src="{{url}}" alt="{{alt}}" class="img-thumbnail" style="max-width: 200px;">
                {{/entry.screenshots}}
            </div>
            {{/entry.screenshots}}
        </div>

        <div class="col-md-4">
            {{#classification.has_maintainer}}
            <div class="card mb-3">
                <div class="card-body">
                    <h6 class="card-title">{{#str}} plugin_maintainer_heading, local_customerportal {{/str}}</h6>
                    <p class="mb-1"><strong>{{classification.maintainer_name}}</strong></p>
                    {{#classification.maintainer_type_label}}
                    <p class="mb-1 text-muted small">{{classification.maintainer_type_label}}</p>
                    {{/classification.maintainer_type_label}}
                    {{#classification.maintainer_certified}}
                    <span class="badge bg-info">
                        {{#str}} badge_maintainer_certified, local_customerportal {{/str}}
                    </span>
                    {{/classification.maintainer_certified}}
                </div>
            </div>
            {{/classification.has_maintainer}}

            {{#has_overlay}}
            {{> local_customerportal/catalog_overlay_block }}
            {{/has_overlay}}

            {{#entry.runbot_demo_id}}
            <p class="mt-3">
                <a
                    href="https://demo.eledia.ai?demo={{entry.runbot_demo_id}}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn btn-primary"
                >
                    {{#str}} demo_start, local_customerportal {{/str}}
                </a>
            </p>
            {{/entry.runbot_demo_id}}
        </div>
    </div>
    {{/has_entry}}
</div>
