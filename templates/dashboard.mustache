{{!
    Dashboard page.
    @template local_customerportal/dashboard
    @copyright 2026 eLeDia GmbH
    @license   https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="path-local-customerportal lh-plugin-shell lh-plugin-shell--wide">
    {{> local_customerportal/shell_header }}

    <div class="lh-plugin-content-area">
        {{#error}}
        <div class="alert alert-warning">{{error}}</div>
        {{/error}}

        <div class="lh-plugin-grid lh-plugin-grid--cols-4 mb-4" role="list">
            <article class="lh-plugin-card" role="listitem">
                <div class="lh-plugin-card__top">
                    <div class="lh-plugin-card__icon lh-plugin-card__icon--community" aria-hidden="true">
                        <i class="fa fa-users"></i>
                    </div>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} installation_registered_users, local_customerportal {{/str}}</div>
                        <h2 class="lh-plugin-card__title">{{siteinfo_registered}}</h2>
                    </div>
                </div>
            </article>
            <article class="lh-plugin-card" role="listitem">
                <div class="lh-plugin-card__top">
                    <div class="lh-plugin-card__icon lh-plugin-card__icon--course" aria-hidden="true">
                        <i class="fa fa-user"></i>
                    </div>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} installation_active_users, local_customerportal {{/str}}</div>
                        <h2 class="lh-plugin-card__title">{{siteinfo_active}}</h2>
                    </div>
                </div>
            </article>
            <article class="lh-plugin-card" role="listitem">
                <div class="lh-plugin-card__top">
                    <div class="lh-plugin-card__icon lh-plugin-card__icon--snack" aria-hidden="true">
                        <i class="fa fa-graduation-cap"></i>
                    </div>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} installation_courses, local_customerportal {{/str}}</div>
                        <h2 class="lh-plugin-card__title">{{siteinfo_courses}}</h2>
                    </div>
                </div>
            </article>
            <article class="lh-plugin-card" role="listitem">
                <div class="lh-plugin-card__top">
                    <div class="lh-plugin-card__icon lh-plugin-card__icon--tour" aria-hidden="true">
                        <i class="fa fa-code-fork"></i>
                    </div>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} installation_moodleversion, local_customerportal {{/str}}</div>
                        <h2 class="lh-plugin-card__title">{{siteinfo_release}}</h2>
                    </div>
                </div>
            </article>
        </div>

        {{#installation}}
        <div class="lh-plugin-grid lh-plugin-grid--cols-4" role="list">
            <article class="lh-plugin-card" role="listitem">
                <div class="lh-plugin-card__top">
                    <div class="lh-plugin-card__icon lh-plugin-card__icon--generic" aria-hidden="true">
                        <i class="fa fa-server"></i>
                    </div>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} installation_heading, local_customerportal {{/str}}</div>
                        <h2 class="lh-plugin-card__title">{{label}}</h2>
                        <p class="lh-plugin-card__body">{{moodle_version}}</p>
                    </div>
                </div>
                <div class="lh-plugin-card__actions">
                    <a href="{{url_installation}}" class="lh-plugin-btn lh-plugin-btn--ghost">
                        <i class="fa fa-arrow-right" aria-hidden="true"></i>
                        {{#str}} nav_installation, local_customerportal {{/str}}
                    </a>
                </div>
            </article>
            <article class="lh-plugin-card" role="listitem">
                <div class="lh-plugin-card__top">
                    <div class="lh-plugin-card__icon lh-plugin-card__icon--course" aria-hidden="true">
                        <i class="fa fa-puzzle-piece"></i>
                    </div>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} nav_myplugins, local_customerportal {{/str}}</div>
                        <h2 class="lh-plugin-card__title">{{plugin_count}}</h2>
                    </div>
                </div>
                <div class="lh-plugin-card__actions">
                    <a href="{{url_myplugins}}" class="lh-plugin-btn lh-plugin-btn--ghost">
                        <i class="fa fa-arrow-right" aria-hidden="true"></i>
                        {{#str}} nav_myplugins, local_customerportal {{/str}}
                    </a>
                </div>
            </article>
            <article class="lh-plugin-card" role="listitem">
                <div class="lh-plugin-card__top">
                    <div class="lh-plugin-card__icon lh-plugin-card__icon--tour" aria-hidden="true">
                        <i class="fa fa-bolt"></i>
                    </div>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} nav_ai, local_customerportal {{/str}}</div>
                        <h2 class="lh-plugin-card__title">{{#str}} ai_setup_short, local_customerportal {{/str}}</h2>
                    </div>
                </div>
                <div class="lh-plugin-card__actions">
                    <a href="{{url_ai_setup}}" class="lh-plugin-btn lh-plugin-btn--ghost">
                        <i class="fa fa-arrow-right" aria-hidden="true"></i>
                        {{#str}} ai_open_setup, local_customerportal {{/str}}
                    </a>
                </div>
            </article>
            <article class="lh-plugin-card" role="listitem">
                <div class="lh-plugin-card__top">
                    <div class="lh-plugin-card__icon lh-plugin-card__icon--community" aria-hidden="true">
                        <i class="fa fa-inbox"></i>
                    </div>
                    <div class="lh-plugin-card__meta">
                        <div class="lh-plugin-card__kicker lh-eyebrow lh-eyebrow--upper">{{#str}} dashboard_open_requests, local_customerportal {{/str}}</div>
                        <h2 class="lh-plugin-card__title">{{open_request_count}}</h2>
                    </div>
                </div>
                <div class="lh-plugin-card__actions">
                    <a href="{{url_requests}}" class="lh-plugin-btn lh-plugin-btn--ghost">
                        <i class="fa fa-arrow-right" aria-hidden="true"></i>
                        {{#str}} nav_requests, local_customerportal {{/str}}
                    </a>
                </div>
            </article>
        </div>
        {{/installation}}

        {{^installation}}
        {{^error}}
        <p class="text-muted">{{#str}} dashboard_no_installation, local_customerportal {{/str}}</p>
        {{/error}}
        {{/installation}}
    </div>
</div>
