{{!
    Plugin catalog list page.
    @template local_customerportal/catalog_list
    @copyright 2026 eLeDia GmbH
    @license   https://www.gnu.org/copyleft/gpl.html GNU GPL v3 or later
}}
<div class="path-local-customerportal">
    {{> local_customerportal/nav_tabs }}

    <form method="get" action="" class="mb-4">
        <div class="d-flex gap-2 mb-2">
            <input type="text" name="q" value="{{q}}" class="form-control"
                   placeholder="{{#str}} catalog_search_placeholder, local_customerportal {{/str}}">
            <button type="submit" class="btn btn-primary">
                {{#str}} catalog_filter_apply, local_customerportal {{/str}}
            </button>
        </div>
        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label small mb-0">
                    {{#str}} catalog_filter_pricing_model, local_customerportal {{/str}}
                </label>
                <select name="pricing_model" class="form-select form-select-sm">
                    {{#pricing_options}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                    {{/pricing_options}}
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small mb-0">
                    {{#str}} catalog_filter_maintenance_badge, local_customerportal {{/str}}
                </label>
                <select name="maintenance_badge" class="form-select form-select-sm">
                    {{#maintenance_options}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                    {{/maintenance_options}}
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small mb-0">
                    {{#str}} catalog_filter_gdpr_readiness, local_customerportal {{/str}}
                </label>
                <select name="gdpr_readiness" class="form-select form-select-sm">
                    {{#gdpr_options}}
                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                    {{/gdpr_options}}
                </select>
            </div>
            <div class="col-md-6 d-flex align-items-end gap-3">
                <div class="form-check">
                    <input type="checkbox" name="is_open_source" value="true"
                           id="filter_is_open_source" class="form-check-input"
                           {{#is_open_source_checked}}checked{{/is_open_source_checked}}>
                    <label class="form-check-label" for="filter_is_open_source">
                        {{#str}} catalog_filter_is_open_source, local_customerportal {{/str}}
                    </label>
                </div>
                <div class="form-check">
                    <input type="checkbox" name="is_eledia_product" value="true"
                           id="filter_is_eledia_product" class="form-check-input"
                           {{#is_eledia_product_checked}}checked{{/is_eledia_product_checked}}>
                    <label class="form-check-label" for="filter_is_eledia_product">
                        {{#str}} catalog_filter_is_eledia_product, local_customerportal {{/str}}
                    </label>
                </div>
            </div>
        </div>
    </form>

    {{#error}}
    <div class="alert alert-warning">{{error}}</div>
    {{/error}}

    {{^error}}
    {{#has_entries}}
    <div class="row">
        {{#entries}}
        <div class="col-md-4 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title">
                        {{title}}
                        {{#has_proven}}<span class="badge bg-success ms-1">{{proven_badge}}</span>{{/has_proven}}
                        {{#is_installed}}<span class="badge bg-info ms-1">{{#str}} overlay_installed, local_customerportal {{/str}}</span>{{/is_installed}}
                        {{#recommended}}<span class="badge bg-primary ms-1">{{#str}} overlay_recommended, local_customerportal {{/str}}</span>{{/recommended}}
                        {{#is_deprecated}}<span class="badge bg-danger ms-1">{{#str}} badge_deprecated, local_customerportal {{/str}}</span>{{/is_deprecated}}
                    </h6>
                    <p class="card-text small text-muted">{{teaser}}</p>
                    <a href="{{url_detail}}" class="btn btn-outline-secondary btn-sm">
                        {{#str}} plugin_heading, local_customerportal {{/str}}
                    </a>
                </div>
                <div class="card-footer bg-transparent d-flex flex-wrap gap-1">
                    {{#has_pricing_model}}
                    <span class="badge bg-light text-dark border">{{pricing_model_label}}</span>
                    {{/has_pricing_model}}
                    {{#is_open_source}}
                    <span class="badge bg-light text-dark border">
                        {{#str}} badge_open_source, local_customerportal {{/str}}
                    </span>
                    {{/is_open_source}}
                    {{#is_eledia_product}}
                    <span class="badge bg-primary">
                        {{#str}} badge_eledia_product, local_customerportal {{/str}}
                    </span>
                    {{/is_eledia_product}}
                    {{#has_gdpr}}
                    <span class="badge {{gdpr_class}}">{{gdpr_label}}</span>
                    {{/has_gdpr}}
                    {{#maintainer_certified}}
                    <span class="badge bg-info">
                        {{#str}} badge_maintainer_certified, local_customerportal {{/str}}
                    </span>
                    {{/maintainer_certified}}
                </div>
            </div>
        </div>
        {{/entries}}
    </div>
    {{/has_entries}}
    {{^has_entries}}
    <p class="text-muted">{{#str}} catalog_no_results, local_customerportal {{/str}}</p>
    {{/has_entries}}
    {{/error}}
</div>
